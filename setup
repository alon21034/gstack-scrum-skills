#!/usr/bin/env bash
# setup — install sprint skill and helper scripts into an existing gstack install

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

GSTACK_ROOT="${GSTACK_ROOT:-}"
COMMANDS_DIR="${COMMANDS_DIR:-}"
INSTALL_HOST="${SETUP_HOST:-auto}"
DRY_RUN=false

is_valid_host() {
  local host="$1"
  case "$host" in
    auto|claude|codex) return 0 ;;
    *) return 1 ;;
  esac
}

default_gstack_root() {
  local host="${1:-auto}"
  case "$host" in
    codex)
      printf "%s\n" "$HOME/.codex/skills/gstack"
      ;;
    claude)
      printf "%s\n" "$HOME/.claude/skills/gstack"
      ;;
    auto)
      if [[ -d "$HOME/.codex/skills/gstack" ]]; then
        printf "%s\n" "$HOME/.codex/skills/gstack"
        return
      fi
      if [[ -d "$HOME/.claude/skills/gstack" ]]; then
        printf "%s\n" "$HOME/.claude/skills/gstack"
        return
      fi
      printf "%s\n" "$HOME/.codex/skills/gstack"
      ;;
  esac
}

default_commands_dir() {
  local host="${1:-auto}"
  case "$host" in
    codex)
      printf "%s\n" "$HOME/.codex/commands"
      ;;
    claude)
      printf "%s\n" "$HOME/.claude/commands"
      ;;
    auto)
      if [[ -d "$HOME/.codex/commands" ]]; then
        printf "%s\n" "$HOME/.codex/commands"
        return
      fi
      if [[ -d "$HOME/.claude/commands" ]]; then
        printf "%s\n" "$HOME/.claude/commands"
        return
      fi
      printf "%s\n" "$HOME/.codex/commands"
      ;;
  esac
}

usage() {
  cat <<'EOF'
Usage: ./setup [options]

Options:
  --host <auto|claude|codex>  Host to target for default paths (default: auto)
  --gstack-root <path>   gstack root directory (default: ~/.codex/skills/gstack, fallback ~/.claude/skills/gstack)
  --commands-dir <path>  commands directory (default: ~/.codex/commands, fallback ~/.claude/commands)
  --dry-run              Print actions without writing files
  -h, --help             Show this help

Environment overrides:
  SETUP_HOST             same as --host
  GSTACK_ROOT            same as --gstack-root
  COMMANDS_DIR           same as --commands-dir
EOF
}

expand_path() {
  local path="$1"
  if [[ "$path" == "~/"* ]]; then
    printf "%s/%s\n" "$HOME" "${path#~/}"
  else
    printf "%s\n" "$path"
  fi
}

run() {
  if $DRY_RUN; then
    printf "[dry-run] %q" "$1"
    shift
    for arg in "$@"; do
      printf " %q" "$arg"
    done
    printf "\n"
    return 0
  fi
  "$@"
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --host)
      [[ $# -ge 2 ]] || { echo "ERROR: --host requires a value" >&2; exit 1; }
      INSTALL_HOST="$2"
      if ! is_valid_host "$INSTALL_HOST"; then
        echo "ERROR: invalid --host value: $INSTALL_HOST (expected auto|claude|codex)" >&2
        exit 1
      fi
      shift 2
      ;;
    --gstack-root)
      [[ $# -ge 2 ]] || { echo "ERROR: --gstack-root requires a value" >&2; exit 1; }
      GSTACK_ROOT="$2"
      shift 2
      ;;
    --commands-dir)
      [[ $# -ge 2 ]] || { echo "ERROR: --commands-dir requires a value" >&2; exit 1; }
      COMMANDS_DIR="$2"
      shift 2
      ;;
    --dry-run)
      DRY_RUN=true
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "ERROR: unknown option: $1" >&2
      usage
      exit 1
      ;;
  esac
done

if ! is_valid_host "$INSTALL_HOST"; then
  echo "ERROR: invalid SETUP_HOST value: $INSTALL_HOST (expected auto|claude|codex)" >&2
  exit 1
fi

if [[ -z "$GSTACK_ROOT" ]]; then
  GSTACK_ROOT="$(default_gstack_root "$INSTALL_HOST")"
fi
if [[ -z "$COMMANDS_DIR" ]]; then
  COMMANDS_DIR="$(default_commands_dir "$INSTALL_HOST")"
fi

GSTACK_ROOT="$(expand_path "$GSTACK_ROOT")"
COMMANDS_DIR="$(expand_path "$COMMANDS_DIR")"

REQUIRED_FILES=(
  "sprint/SKILL.md"
  "sprint/SKILL.md.tmpl"
  "bin/sprint-setup"
  "bin/sprint-board"
  "bin/sprint-approve"
  "commands/sprint-task.md"
  "commands/sprint-board.md"
  "commands/sprint-approve.md"
)

for rel in "${REQUIRED_FILES[@]}"; do
  if [[ ! -f "$SCRIPT_DIR/$rel" ]]; then
    echo "ERROR: missing required file: $SCRIPT_DIR/$rel" >&2
    exit 1
  fi
done

if [[ ! -d "$GSTACK_ROOT" ]]; then
  cat >&2 <<EOF
ERROR: gstack root not found: $GSTACK_ROOT
Install gstack first, for example:
  git clone --single-branch --depth 1 https://github.com/garrytan/gstack.git ~/.codex/skills/gstack
  cd ~/.codex/skills/gstack && ./setup
(Claude users can use ~/.claude/skills/gstack instead.)
EOF
  exit 1
fi

run mkdir -p "$GSTACK_ROOT/sprint" "$GSTACK_ROOT/bin" "$COMMANDS_DIR"

run install -m 0644 "$SCRIPT_DIR/sprint/SKILL.md" "$GSTACK_ROOT/sprint/SKILL.md"
run install -m 0644 "$SCRIPT_DIR/sprint/SKILL.md.tmpl" "$GSTACK_ROOT/sprint/SKILL.md.tmpl"

run install -m 0755 "$SCRIPT_DIR/bin/sprint-setup" "$GSTACK_ROOT/bin/sprint-setup"
run install -m 0755 "$SCRIPT_DIR/bin/sprint-board" "$GSTACK_ROOT/bin/sprint-board"
run install -m 0755 "$SCRIPT_DIR/bin/sprint-approve" "$GSTACK_ROOT/bin/sprint-approve"

run install -m 0644 "$SCRIPT_DIR/commands/sprint-board.md" "$COMMANDS_DIR/sprint-board.md"
run install -m 0644 "$SCRIPT_DIR/commands/sprint-approve.md" "$COMMANDS_DIR/sprint-approve.md"
run install -m 0644 "$SCRIPT_DIR/commands/sprint-task.md" "$COMMANDS_DIR/sprint-task.md"

if $DRY_RUN; then
  echo "Dry run complete."
  exit 0
fi

cat <<EOF
Install complete.

Installed into:
  host mode:   $INSTALL_HOST
  gstack root: $GSTACK_ROOT
  commands:    $COMMANDS_DIR

Quick checks:
  ls $GSTACK_ROOT/bin/sprint-{setup,board,approve}
  ls $GSTACK_ROOT/sprint/SKILL.md
  ls $COMMANDS_DIR/sprint-{task,board,approve}.md
EOF
