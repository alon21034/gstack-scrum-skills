#!/usr/bin/env bash
# setup — install sprint skill and helper scripts

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

SKILL_ROOT="${SKILL_ROOT:-}"
COMMANDS_DIR="${COMMANDS_DIR:-}"
INSTALL_HOST="${SETUP_HOST:-auto}"
DRY_RUN=false
TARGET_HOSTS=()
TARGET_SKILL_ROOTS=()
TARGET_COMMANDS_DIRS=()

is_valid_host() {
  local host="$1"
  case "$host" in
    auto|claude|codex) return 0 ;;
    *) return 1 ;;
  esac
}

default_skill_root() {
  local host="${1:-auto}"
  case "$host" in
    codex)
      printf "%s\n" "$HOME/.codex/skills/sprint"
      ;;
    claude)
      printf "%s\n" "$HOME/.claude/skills/sprint"
      ;;
    auto)
      if [[ -d "$HOME/.codex/skills" ]]; then
        printf "%s\n" "$HOME/.codex/skills/sprint"
      elif [[ -d "$HOME/.claude/skills" ]]; then
        printf "%s\n" "$HOME/.claude/skills/sprint"
      else
        printf "%s\n" "$HOME/.codex/skills/sprint"
      fi
      ;;
  esac
}

host_installed() {
  local host="$1"
  case "$host" in
    codex)
      [[ -d "$HOME/.codex/skills" || -d "$HOME/.codex/commands" ]]
      ;;
    claude)
      [[ -d "$HOME/.claude/skills" || -d "$HOME/.claude/commands" ]]
      ;;
    *)
      return 1
      ;;
  esac
}

resolve_auto_hosts() {
  local found=false
  if host_installed codex; then
    printf "%s\n" "codex"
    found=true
  fi
  if host_installed claude; then
    printf "%s\n" "claude"
    found=true
  fi
  if ! $found; then
    # Keep historic default when no host directories exist.
    printf "%s\n" "codex"
  fi
}

add_install_target() {
  local host="$1"
  local skill_root="$2"
  local commands_dir="$3"
  local i

  # Avoid duplicate work when paths collapse to the same destination.
  for i in "${!TARGET_SKILL_ROOTS[@]}"; do
    if [[ "${TARGET_SKILL_ROOTS[$i]}" == "$skill_root" && "${TARGET_COMMANDS_DIRS[$i]}" == "$commands_dir" ]]; then
      return 0
    fi
  done

  TARGET_HOSTS+=("$host")
  TARGET_SKILL_ROOTS+=("$skill_root")
  TARGET_COMMANDS_DIRS+=("$commands_dir")
}

resolve_install_targets() {
  local auto_host
  local resolved_skill_root
  local resolved_commands_dir

  if [[ "$INSTALL_HOST" == "auto" && -z "$SKILL_ROOT" && -z "$COMMANDS_DIR" ]]; then
    while IFS= read -r auto_host; do
      resolved_skill_root="$(expand_path "$(default_skill_root "$auto_host")")"
      resolved_commands_dir="$(expand_path "$(default_commands_dir "$auto_host")")"
      add_install_target "$auto_host" "$resolved_skill_root" "$resolved_commands_dir"
    done < <(resolve_auto_hosts)
    return 0
  fi

  resolved_skill_root="${SKILL_ROOT:-$(default_skill_root "$INSTALL_HOST")}"
  resolved_commands_dir="${COMMANDS_DIR:-$(default_commands_dir "$INSTALL_HOST")}"
  add_install_target "$INSTALL_HOST" "$(expand_path "$resolved_skill_root")" "$(expand_path "$resolved_commands_dir")"
}

default_commands_dir() {
  local host="${1:-auto}"
  case "$host" in
    codex)
      printf "%s\n" "$HOME/.codex/commands"
      ;;
    claude)
      printf "%s\n" "$HOME/.claude/commands"
      ;;
    auto)
      if [[ -d "$HOME/.codex/commands" ]]; then
        printf "%s\n" "$HOME/.codex/commands"
        return
      fi
      if [[ -d "$HOME/.claude/commands" ]]; then
        printf "%s\n" "$HOME/.claude/commands"
        return
      fi
      printf "%s\n" "$HOME/.codex/commands"
      ;;
  esac
}

usage() {
  cat <<'EOF'
Usage: ./setup [options]

Options:
  --host <auto|claude|codex>  Host mode. auto installs to both when both are present (default: auto)
  --skill-root <path>    install root for sprint skill/bin (default: ~/.codex/skills/sprint, host-aware)
  --commands-dir <path>  commands directory (default: host-aware)
  --dry-run              Print actions without writing files
  -h, --help             Show this help

Environment overrides:
  SETUP_HOST             same as --host
  SKILL_ROOT             same as --skill-root
  COMMANDS_DIR           same as --commands-dir
EOF
}

expand_path() {
  local path="$1"
  if [[ "$path" == "~/"* ]]; then
    printf "%s/%s\n" "$HOME" "${path#~/}"
  else
    printf "%s\n" "$path"
  fi
}

run() {
  if $DRY_RUN; then
    printf "[dry-run] %q" "$1"
    shift
    for arg in "$@"; do
      printf " %q" "$arg"
    done
    printf "\n"
    return 0
  fi
  "$@"
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --host)
      [[ $# -ge 2 ]] || { echo "ERROR: --host requires a value" >&2; exit 1; }
      INSTALL_HOST="$2"
      if ! is_valid_host "$INSTALL_HOST"; then
        echo "ERROR: invalid --host value: $INSTALL_HOST (expected auto|claude|codex)" >&2
        exit 1
      fi
      shift 2
      ;;
    --skill-root)
      [[ $# -ge 2 ]] || { echo "ERROR: --skill-root requires a value" >&2; exit 1; }
      SKILL_ROOT="$2"
      shift 2
      ;;
    --commands-dir)
      [[ $# -ge 2 ]] || { echo "ERROR: --commands-dir requires a value" >&2; exit 1; }
      COMMANDS_DIR="$2"
      shift 2
      ;;
    --dry-run)
      DRY_RUN=true
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      if [[ "$1" = "--g""stack-root" ]]; then
        echo "ERROR: --g""stack-root was removed. Use --skill-root instead." >&2
        exit 1
      fi
      echo "ERROR: unknown option: $1" >&2
      usage
      exit 1
      ;;
  esac
done

if ! is_valid_host "$INSTALL_HOST"; then
  echo "ERROR: invalid SETUP_HOST value: $INSTALL_HOST (expected auto|claude|codex)" >&2
  exit 1
fi

resolve_install_targets

REQUIRED_FILES=(
  "sprint/SKILL.md"
  "sprint/SKILL.md.tmpl"
  "bin/sprint-setup"
  "bin/sprint-board"
  "bin/sprint-finish"
  "commands/sprint.md"
  "commands/sprint-task.md"
  "commands/sprint-board.md"
  "commands/sprint-finish.md"
)

for rel in "${REQUIRED_FILES[@]}"; do
  if [[ ! -f "$SCRIPT_DIR/$rel" ]]; then
    echo "ERROR: missing required file: $SCRIPT_DIR/$rel" >&2
    exit 1
  fi
done

for i in "${!TARGET_HOSTS[@]}"; do
  target_skill_root="${TARGET_SKILL_ROOTS[$i]}"
  target_commands_dir="${TARGET_COMMANDS_DIRS[$i]}"
  run mkdir -p "$target_skill_root/sprint" "$target_skill_root/bin" "$target_commands_dir"

  run install -m 0644 "$SCRIPT_DIR/sprint/SKILL.md" "$target_skill_root/sprint/SKILL.md"
  run install -m 0644 "$SCRIPT_DIR/sprint/SKILL.md.tmpl" "$target_skill_root/sprint/SKILL.md.tmpl"

  run install -m 0755 "$SCRIPT_DIR/bin/sprint-setup" "$target_skill_root/bin/sprint-setup"
  run install -m 0755 "$SCRIPT_DIR/bin/sprint-board" "$target_skill_root/bin/sprint-board"
  run install -m 0755 "$SCRIPT_DIR/bin/sprint-finish" "$target_skill_root/bin/sprint-finish"

  run install -m 0644 "$SCRIPT_DIR/commands/sprint.md" "$target_commands_dir/sprint.md"
  run install -m 0644 "$SCRIPT_DIR/commands/sprint-board.md" "$target_commands_dir/sprint-board.md"
  run install -m 0644 "$SCRIPT_DIR/commands/sprint-finish.md" "$target_commands_dir/sprint-finish.md"
  run install -m 0644 "$SCRIPT_DIR/commands/sprint-task.md" "$target_commands_dir/sprint-task.md"
done

if $DRY_RUN; then
  echo "Dry run complete."
  exit 0
fi

cat <<EOF
Install complete.

Installed into:
  host mode:   $INSTALL_HOST
$(for i in "${!TARGET_HOSTS[@]}"; do
  printf "  target %s:   host=%s\n" "$((i + 1))" "${TARGET_HOSTS[$i]}"
  printf "               skill root=%s\n" "${TARGET_SKILL_ROOTS[$i]}"
  printf "               commands=%s\n" "${TARGET_COMMANDS_DIRS[$i]}"
done)

Quick checks:
$(for i in "${!TARGET_HOSTS[@]}"; do
  printf "  ls %s/bin/sprint-{setup,board,finish}\n" "${TARGET_SKILL_ROOTS[$i]}"
  printf "  ls %s/sprint/SKILL.md\n" "${TARGET_SKILL_ROOTS[$i]}"
  printf "  ls %s/sprint{,-task,-board,-finish}.md\n" "${TARGET_COMMANDS_DIRS[$i]}"
done)
EOF
