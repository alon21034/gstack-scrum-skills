#!/usr/bin/env bash
# sprint-setup — Conductor workspace bootstrap for gstack sprint
# Usage: sprint-setup <workspace-name> <conductor-root-path>
# Called by conductor.json scripts.setup on workspace creation.
#
# What it does:
#   1. Validates the sprint file exists and is valid JSON
#   2. Atomically claims first available pending task (using mkdir lock)
#   3. Creates a git branch for the task
#   4. Writes a /sprint-task slash command to .codex/commands/ or .claude/commands/
#   5. Writes .sprint-task-prompt.txt for the conductor.json run script
#
# On any failure after claiming, trap ERR rolls the task back to "pending".

set -euo pipefail

check_for_sprint_upgrade() {
  if [ "${SPRINT_SKIP_UPGRADE_CHECK:-0}" = "1" ]; then
    return 0
  fi

  local checker=""
  local script_dir
  local check_output
  local check_rc

  if command -v sprint-upgrade >/dev/null 2>&1; then
    checker="$(command -v sprint-upgrade)"
  else
    script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    if [ -x "$script_dir/sprint-upgrade" ]; then
      checker="$script_dir/sprint-upgrade"
    fi
  fi

  if [ -z "$checker" ]; then
    return 0
  fi

  if check_output="$("$checker" --check --quiet 2>/dev/null)"; then
    return 0
  else
    check_rc=$?
  fi

  case "$check_rc" in
    10)
      if [ -n "$check_output" ]; then
        printf '%s\n' "$check_output" >&2
      fi
      ;;
    *)
      # Keep command flow resilient when check cannot be completed.
      ;;
  esac
}

check_for_sprint_upgrade

WORKSPACE_NAME="${1:-$CONDUCTOR_WORKSPACE_NAME}"
ROOT_PATH="${2:-$CONDUCTOR_ROOT_PATH}"

if [ -z "$WORKSPACE_NAME" ] || [ -z "$ROOT_PATH" ]; then
  echo "ERROR: Usage: sprint-setup <workspace-name> <conductor-root-path>" >&2
  echo "       Or set CONDUCTOR_WORKSPACE_NAME and CONDUCTOR_ROOT_PATH env vars." >&2
  exit 1
fi

# Guard: jq required
command -v jq >/dev/null 2>&1 || {
  echo "ERROR: jq is required. Install with: brew install jq" >&2
  exit 1
}

CONTEXT_DIR="$ROOT_PATH/.context"
SPRINT_FILE="$CONTEXT_DIR/.sprint.json"
LOCK_DIR="$CONTEXT_DIR/.sprint.lockdir"

# --- Lockdir-based mutual exclusion (no flock needed) ---
# mkdir is atomic on POSIX — only one process succeeds.
acquire_lock() {
  local max_wait="${1:-10}"
  local waited=0
  while ! mkdir "$LOCK_DIR" 2>/dev/null; do
    sleep 0.2
    waited=$(echo "$waited + 0.2" | bc)
    if [ "$(echo "$waited >= $max_wait" | bc)" -eq 1 ]; then
      echo "ERROR: Could not acquire sprint lock after ${max_wait}s. Another workspace may be writing." >&2
      return 1
    fi
  done
}

release_lock() {
  rmdir "$LOCK_DIR" 2>/dev/null || true
}

# Safety: always release lock on exit if we hold it
trap 'release_lock' EXIT

# --- Helper: atomically update sprint file under lock ---
sprint_update() {
  # Usage: sprint_update <jq-filter> [jq-args...]
  # Acquires lock, runs jq, writes atomically, releases lock.
  local filter="$1"
  shift
  acquire_lock 10
  jq "$@" "$filter" "$SPRINT_FILE" > "$SPRINT_FILE.tmp" && mv "$SPRINT_FILE.tmp" "$SPRINT_FILE"
  release_lock
}

# Validate sprint file exists and is valid JSON
[ -f "$SPRINT_FILE" ] || {
  echo "ERROR: Sprint file not found at $SPRINT_FILE" >&2
  echo "       Run /sprint in a CC session to create a sprint first." >&2
  exit 1
}
jq empty "$SPRINT_FILE" 2>/dev/null || {
  echo "ERROR: Sprint file is not valid JSON: $SPRINT_FILE" >&2
  exit 1
}

# Check sprint is active
SPRINT_STATUS=$(jq -r '.sprint.status' "$SPRINT_FILE")
if [ "$SPRINT_STATUS" != "active" ]; then
  echo "ERROR: Sprint status is '$SPRINT_STATUS' — no active sprint to join." >&2
  exit 1
fi

BLOCKER_CHECK_BRANCH="${SPRINT_BLOCKER_CHECK_BRANCH:-main}"

resolve_branch_head_commit() {
  local branch="$1"
  local ref=""

  if git rev-parse --verify "${branch}^{commit}" >/dev/null 2>&1; then
    ref="$branch"
  elif git rev-parse --verify "origin/${branch}^{commit}" >/dev/null 2>&1; then
    ref="origin/${branch}"
  else
    return 1
  fi

  git rev-parse "${ref}^{commit}" 2>/dev/null
}

refresh_review_tasks_from_git_log() {
  local main_ref="$1"
  local review_commit=""
  local task_id=""
  local task_branch=""
  local ids_json=""
  local completed_ts=""
  local resolved_ids=()

  if ! git rev-parse --verify "${main_ref}^{commit}" >/dev/null 2>&1; then
    return 0
  fi

  while IFS=$'\t' read -r task_id task_branch; do
    if [ -z "$task_id" ] || [ -z "$task_branch" ]; then
      continue
    fi

    if ! review_commit="$(resolve_branch_head_commit "$task_branch")"; then
      continue
    fi

    if git log --format=%H "$main_ref" | grep -Fxq "$review_commit"; then
      resolved_ids+=("$task_id")
    fi
  done < <(jq -r '
    .tasks[]
    | select(.status == "review")
    | select((.branch // "") != "")
    | "\(.id | tostring)\t\(.branch)"
  ' "$SPRINT_FILE")

  if [ "${#resolved_ids[@]}" -eq 0 ]; then
    return 0
  fi

  ids_json="$(printf '%s\n' "${resolved_ids[@]}" | jq -Rsc 'split("\n") | map(select(length > 0))')"
  completed_ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"

  jq --argjson ids "$ids_json" --arg ts "$completed_ts" '
    .tasks |= map(
      if (.status == "review" and ((.id | tostring) as $task_id | (($ids | index($task_id)) != null)))
      then .status = "done" | .completed_at = (.completed_at // $ts)
      else .
      end
    )
  ' "$SPRINT_FILE" > "$SPRINT_FILE.tmp" && mv "$SPRINT_FILE.tmp" "$SPRINT_FILE"

  echo "Auto-resolved review blockers via git log on ${main_ref}: ${resolved_ids[*]}"
}

# Claim a task atomically
# If all pending tasks are blocked by dependencies, prompt the user to wait or exit.
TASK_ID=""
TASK_TITLE=""
TASK_DESC=""
MAX_RETRIES=120      # 120 retries × 10s = up to ~20 minutes of waiting
RETRY_INTERVAL=10    # seconds between retries
CLAIMED=0
PROMPTED_WAIT=0

for attempt in $(seq 1 "$MAX_RETRIES"); do
  acquire_lock 10

  # Review tasks can silently stop being blockers once their branch head appears on main.
  refresh_review_tasks_from_git_log "$BLOCKER_CHECK_BRANCH"

  # Find first pending task whose dependencies (if any) all exist and are done.
  # Missing dependency IDs must keep the task blocked.
  TASK_ID=$(jq -r '
    . as $root |
    ($root.tasks | map({key: (.id | tostring), value: .status}) | from_entries) as $status_by_id |
    [.tasks[] | select(.status == "pending") |
     select(
       (.depends_on // []) as $deps |
       ($deps | length) == 0 or
       ($deps | all((($status_by_id[(. | tostring)] // "__MISSING__") == "done")))
     )]
    | .[0].id
  ' "$SPRINT_FILE")

  if [ -n "$TASK_ID" ] && [ "$TASK_ID" != "null" ]; then
    # Mark task as in-progress and record workspace
    jq --arg ws "$WORKSPACE_NAME" --argjson id "$TASK_ID" \
      --arg ts "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
      '(.tasks[] | select(.id == $id)).status = "in-progress" |
       (.tasks[] | select(.id == $id)).workspace = $ws |
       (.tasks[] | select(.id == $id)).started_at = $ts' \
      "$SPRINT_FILE" > "$SPRINT_FILE.tmp" && mv "$SPRINT_FILE.tmp" "$SPRINT_FILE"
    release_lock
    CLAIMED=1
    break
  fi

  # No claimable task — check why
  BLOCKED_COUNT=$(jq '[.tasks[] | select(.status == "pending")] | length' "$SPRINT_FILE")
  release_lock

  if [ "$BLOCKED_COUNT" -eq "0" ]; then
    echo "No pending tasks available — all tasks claimed or completed." >&2
    exit 1
  fi

  # First time hitting blocked deps: show blockers and prompt user
  if [ "$PROMPTED_WAIT" -eq 0 ]; then
    echo ""
    echo "⏳ $BLOCKED_COUNT pending task(s) are waiting for dependencies to complete."
    echo ""
    echo "Blocked tasks:"
    jq -r '
      . as $root |
      .tasks[] | select(.status == "pending") |
      select((.depends_on // []) | length > 0) |
      select((.depends_on // []) | map(. as $dep | $root.tasks[] | select(.id == $dep) | .status == "done") | all | not) |
      "  Task \(.id): \(.title)  ←  blocked by: \(
        [.depends_on[] | . as $dep | $root.tasks[] | select(.id == $dep) | select(.status != "done") |
         "task \(.id) (\(.status))"] | join(", ")
      )"
    ' "$SPRINT_FILE"
    echo ""
    printf "Wait for blockers to finish? This will retry for up to 20 minutes. (yes/no): "
    if ! IFS= read -r answer < /dev/tty 2>/dev/null; then
      # Non-interactive — default to wait
      answer="yes"
    fi
    answer="$(echo "$answer" | tr '[:upper:]' '[:lower:]' | xargs)"
    case "$answer" in
      yes|y)
        echo "Will poll every ${RETRY_INTERVAL}s for up to ~20 minutes. If it times out, manually restart the workspace to try again."
        PROMPTED_WAIT=1
        ;;
      *)
        echo "Exiting — no available tasks to claim." >&2
        exit 1
        ;;
    esac
  else
    echo "Still waiting for dependencies... ($BLOCKED_COUNT pending, attempt $attempt/$MAX_RETRIES)" >&2
  fi

  sleep "$RETRY_INTERVAL"
done

if [ "$CLAIMED" -ne 1 ]; then
  echo "ERROR: Timed out waiting for dependencies to resolve after ~20 minutes. Please manually restart the workspace to try again." >&2
  exit 1
fi

# Read back claimed task details
TASK_ID=$(jq -r --arg ws "$WORKSPACE_NAME" \
  '.tasks[] | select(.workspace == $ws and .status == "in-progress") | .id' \
  "$SPRINT_FILE")

if [ -z "$TASK_ID" ] || [ "$TASK_ID" = "null" ]; then
  echo "ERROR: Failed to claim task (lock race or file error)." >&2
  exit 1
fi

TASK_TITLE=$(jq -r --argjson id "$TASK_ID" '.tasks[] | select(.id == $id) | .title' "$SPRINT_FILE")
TASK_DESC=$(jq -r --argjson id "$TASK_ID" '.tasks[] | select(.id == $id) | .description' "$SPRINT_FILE")
SPRINT_ID=$(jq -r '.sprint.id' "$SPRINT_FILE")
SPRINT_TOPIC=$(jq -r '.sprint.topic' "$SPRINT_FILE")

echo "Claimed task $TASK_ID: $TASK_TITLE"

# Rollback task to pending if any subsequent step fails
rollback() {
  echo "sprint-setup failed — rolling task $TASK_ID back to pending." >&2
  if mkdir "$LOCK_DIR" 2>/dev/null; then
    jq --argjson id "$TASK_ID" \
      '(.tasks[] | select(.id == $id)).status = "pending" |
       (.tasks[] | select(.id == $id)).workspace = null |
       (.tasks[] | select(.id == $id)).started_at = null' \
      "$SPRINT_FILE" > "$SPRINT_FILE.tmp" 2>/dev/null && mv "$SPRINT_FILE.tmp" "$SPRINT_FILE" || true
    rmdir "$LOCK_DIR" 2>/dev/null || true
  fi
}
trap rollback ERR

# Write task details to .context/ (no files outside .context/)
CONTEXT_DIR="$(dirname "$SPRINT_FILE")"
mkdir -p "$CONTEXT_DIR"

LOCK_DIR_REL=".context/.sprint.lockdir"

cat > "$CONTEXT_DIR/sprint-task-${TASK_ID}.md" << SPRINT_TASK_EOF
Read the task from .context/.sprint.json (task id: ${TASK_ID}).
Sprint: ${SPRINT_TOPIC}
Task: ${TASK_TITLE}

Full task description:
${TASK_DESC}

Instructions:
1. Read .context/.sprint.json to understand the full sprint context.
2. Show the user a short task brief:
   - sprint topic
   - task id and title
   - full description (including acceptance criteria)
   - current branch
3. Ask for explicit approval before implementation:
   "Approve start implementation for task ${TASK_ID}? (yes/no)"
4. Do NOT implement anything until the user clearly approves.
5. After approval, implement only this task's scope.
6. When implementation is complete, verify acceptance criteria BEFORE marking review:
   - Parse the "## Acceptance Criteria" section from the task description above
   - Check each criterion against your actual implementation
   - Report results in this format:
     Acceptance Criteria Check:
     [PASS] criterion description
     [FAIL] criterion description — reason for failure
     Result: X/Y passed
   - If ALL criteria pass, proceed to step 7.
   - If any criteria FAIL, show the report and ask the user:
     "Some acceptance criteria failed. Options: A) Fix the failing criteria B) Mark as review anyway C) Backlog this task"
   - Only proceed to step 7 after all criteria pass or user explicitly approves.
7. Update the task status to "review" using a lockdir for safe concurrent access:
   while ! mkdir ${LOCK_DIR_REL} 2>/dev/null; do sleep 0.2; done; jq --argjson id ${TASK_ID} '(.tasks[] | select(.id == \$id)).status = "review"' .context/.sprint.json > .context/.sprint.json.tmp && mv .context/.sprint.json.tmp .context/.sprint.json; rmdir ${LOCK_DIR_REL}; sprint-board .context/.sprint.json >/dev/null 2>&1 || ./bin/sprint-board .context/.sprint.json >/dev/null 2>&1
8. Summarize what you changed and why, including the acceptance criteria results.
9. Do NOT merge or create a PR — the human reviewer will run sprint-finish when ready to close the sprint.
SPRINT_TASK_EOF

echo "Wrote task details to $CONTEXT_DIR/sprint-task-${TASK_ID}.md"
echo "Sprint setup complete. Task $TASK_ID ($TASK_TITLE) is ready."
