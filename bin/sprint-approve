#!/usr/bin/env bash
# sprint-approve — Mark a sprint task as done (human review gate)
# Usage: sprint-approve <task-id> [path-to-sprint-file]
# Default sprint file: .gstack-sprint.json in current directory
#
# Validates the task is in "review" status before approving.
# Updates status to "done" and sets completed_at timestamp.
# If all tasks are done, updates sprint.status to "complete".

set -euo pipefail

TASK_ID="${1:-}"
SPRINT_FILE="${2:-.gstack-sprint.json}"

if [ -z "$TASK_ID" ]; then
  echo "Usage: sprint-approve <task-id> [path-to-sprint-file]" >&2
  echo "Example: sprint-approve 1" >&2
  exit 1
fi

# Numeric validation
if ! [[ "$TASK_ID" =~ ^[0-9]+$ ]]; then
  echo "ERROR: Task ID must be a number. Got: $TASK_ID" >&2
  exit 1
fi

TASK_ID_NUM=$((TASK_ID))  # normalize to integer

# Guards
command -v jq >/dev/null 2>&1 || {
  echo "ERROR: jq is required. Install with: brew install jq" >&2
  exit 1
}

[ -f "$SPRINT_FILE" ] || {
  echo "ERROR: Sprint file not found: $SPRINT_FILE" >&2
  echo "Usage: sprint-approve <task-id> [path-to-sprint-file]" >&2
  exit 1
}

jq empty "$SPRINT_FILE" 2>/dev/null || {
  echo "ERROR: Sprint file is not valid JSON: $SPRINT_FILE" >&2
  exit 1
}

# Check task exists
TASK_EXISTS=$(jq --argjson id "$TASK_ID_NUM" '.tasks[] | select(.id == $id) | .id' "$SPRINT_FILE")
if [ -z "$TASK_EXISTS" ]; then
  TOTAL=$(jq '.tasks | length' "$SPRINT_FILE")
  echo "ERROR: Task $TASK_ID_NUM not found. Sprint has $TOTAL task(s)." >&2
  jq -r '.tasks[] | "  Task \(.id): \(.title) [\(.status)]"' "$SPRINT_FILE" >&2
  exit 1
fi

# Validate task is in "review" status
CURRENT_STATUS=$(jq -r --argjson id "$TASK_ID_NUM" '.tasks[] | select(.id == $id) | .status' "$SPRINT_FILE")
if [ "$CURRENT_STATUS" != "review" ]; then
  echo "ERROR: Task $TASK_ID_NUM is in '$CURRENT_STATUS' status, not 'review'. Cannot approve." >&2
  echo "       The agent must mark the task as 'review' before you can approve it." >&2
  case "$CURRENT_STATUS" in
    pending)    echo "       This task hasn't been started yet." >&2 ;;
    in-progress) echo "       This task is still being worked on by an agent." >&2 ;;
    done)       echo "       This task is already done." >&2 ;;
  esac
  exit 1
fi

TASK_TITLE=$(jq -r --argjson id "$TASK_ID_NUM" '.tasks[] | select(.id == $id) | .title' "$SPRINT_FILE")
COMPLETED_AT=$(date -u +%Y-%m-%dT%H:%M:%SZ)

# Update task to done
jq --argjson id "$TASK_ID_NUM" --arg ts "$COMPLETED_AT" \
  '(.tasks[] | select(.id == $id)).status = "done" |
   (.tasks[] | select(.id == $id)).completed_at = $ts' \
  "$SPRINT_FILE" > "$SPRINT_FILE.tmp" && mv "$SPRINT_FILE.tmp" "$SPRINT_FILE"

# Count progress
DONE_COUNT=$(jq '[.tasks[] | select(.status == "done")] | length' "$SPRINT_FILE")
TOTAL_COUNT=$(jq '.tasks | length' "$SPRINT_FILE")

echo "Task $TASK_ID_NUM done: $TASK_TITLE"
echo "Sprint progress: $DONE_COUNT/$TOTAL_COUNT complete"

# If all tasks done, mark sprint complete
if [ "$DONE_COUNT" -eq "$TOTAL_COUNT" ]; then
  jq '.sprint.status = "complete"' "$SPRINT_FILE" > "$SPRINT_FILE.tmp" && mv "$SPRINT_FILE.tmp" "$SPRINT_FILE"
  SPRINT_TOPIC=$(jq -r '.sprint.topic' "$SPRINT_FILE")
  echo ""
  echo "Sprint complete: $SPRINT_TOPIC"
  echo "All $TOTAL_COUNT task(s) done."
fi
