#!/usr/bin/env bash
# sprint-upgrade — Upgrade sprint skills package and reinstall commands
# Usage:
#   sprint-upgrade [--repo <path>] [setup options...]
#   sprint-upgrade --check [--quiet] [--repo <path>]

set -euo pipefail

usage() {
  cat <<'USAGE'
Usage:
  sprint-upgrade [--repo <path>] [setup options...]
  sprint-upgrade --check [--quiet] [--repo <path>]

Options:
  --repo <path>  Use this sprint repository path instead of auto-detecting.
  --check        Check if an upgrade is available, but do not modify anything.
  --quiet        With --check, suppress non-actionable output.
  -h, --help     Show this help.

Any additional arguments are passed through to ./setup.
Examples:
  sprint-upgrade
  sprint-upgrade --check
  sprint-upgrade --check --quiet
  sprint-upgrade --host codex
  sprint-upgrade --repo ~/.codex/skills/sprint --host auto
USAGE
}

REPO_HINT=""
CHECK_ONLY=false
QUIET=false
SETUP_ARGS=()

while [ "$#" -gt 0 ]; do
  case "$1" in
    --repo)
      if [ "$#" -lt 2 ]; then
        echo "ERROR: --repo requires a path" >&2
        exit 1
      fi
      REPO_HINT="$2"
      shift 2
      ;;
    --check)
      CHECK_ONLY=true
      shift
      ;;
    --quiet)
      QUIET=true
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      SETUP_ARGS+=("$1")
      shift
      ;;
  esac
done

if $CHECK_ONLY && [ "${#SETUP_ARGS[@]}" -gt 0 ]; then
  echo "ERROR: setup options cannot be used with --check." >&2
  exit 1
fi

command -v git >/dev/null 2>&1 || {
  echo "ERROR: git is required." >&2
  exit 1
}

resolve_repo_root() {
  if [ -n "$REPO_HINT" ]; then
    echo "$REPO_HINT"
    return 0
  fi

  local self_root
  self_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
  if [ -f "$self_root/setup" ]; then
    echo "$self_root"
    return 0
  fi

  local candidate
  for candidate in "$HOME/.codex/skills/sprint" "$HOME/.claude/skills/sprint"; do
    if [ -f "$candidate/setup" ]; then
      echo "$candidate"
      return 0
    fi
  done

  return 1
}

check_upgrade_status() {
  local repo_root="$1"
  local branch upstream target_ref local_sha target_sha local_short target_short

  branch="$(git -C "$repo_root" rev-parse --abbrev-ref HEAD 2>/dev/null || true)"
  if [ -z "$branch" ] || [ "$branch" = "HEAD" ]; then
    if ! $QUIET; then
      echo "Could not check upgrades: repository is in detached HEAD state." >&2
    fi
    return 11
  fi

  if ! git -C "$repo_root" fetch --quiet --all --prune; then
    if ! $QUIET; then
      echo "Could not check upgrades: failed to fetch remotes." >&2
    fi
    return 11
  fi

  upstream="$(git -C "$repo_root" rev-parse --abbrev-ref --symbolic-full-name '@{u}' 2>/dev/null || true)"
  if [ -n "$upstream" ]; then
    target_ref="$upstream"
  else
    target_ref="origin/$branch"
    if ! git -C "$repo_root" show-ref --verify --quiet "refs/remotes/$target_ref"; then
      if ! $QUIET; then
        echo "Could not check upgrades: no upstream and missing $target_ref." >&2
      fi
      return 11
    fi
  fi

  local_sha="$(git -C "$repo_root" rev-parse HEAD)"
  target_sha="$(git -C "$repo_root" rev-parse "$target_ref" 2>/dev/null || true)"
  if [ -z "$target_sha" ]; then
    if ! $QUIET; then
      echo "Could not check upgrades: could not resolve $target_ref." >&2
    fi
    return 11
  fi

  local_short="$(git -C "$repo_root" rev-parse --short "$local_sha")"
  target_short="$(git -C "$repo_root" rev-parse --short "$target_sha")"

  if [ "$local_sha" = "$target_sha" ]; then
    if ! $QUIET; then
      echo "Already up to date at $local_short"
    fi
    return 0
  fi

  if git -C "$repo_root" merge-base --is-ancestor "$local_sha" "$target_sha"; then
    echo "Upgrade available: $local_short -> $target_short. Run sprint-upgrade."
    return 10
  fi

  if git -C "$repo_root" merge-base --is-ancestor "$target_sha" "$local_sha"; then
    if ! $QUIET; then
      echo "Local repository is ahead of $target_ref."
    fi
    return 0
  fi

  echo "Upgrade attention needed: local branch has diverged from $target_ref."
  return 10
}

if ! REPO_ROOT="$(resolve_repo_root)"; then
  echo "ERROR: Could not locate sprint repository root." >&2
  echo "Provide it explicitly: sprint-upgrade --repo <path>" >&2
  exit 1
fi

REPO_ROOT="$(cd "$REPO_ROOT" && pwd)"

if [ ! -f "$REPO_ROOT/setup" ]; then
  echo "ERROR: setup script not found at $REPO_ROOT/setup" >&2
  exit 1
fi

if ! git -C "$REPO_ROOT" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  echo "ERROR: $REPO_ROOT is not a git repository. Cannot self-upgrade." >&2
  echo "Reinstall by cloning the latest repo, then run ./setup." >&2
  exit 1
fi

if $CHECK_ONLY; then
  if check_upgrade_status "$REPO_ROOT"; then
    exit 0
  else
    check_rc=$?
  fi

  case "$check_rc" in
    10) exit 10 ;;
    11) exit 11 ;;
    *) exit 1 ;;
  esac
fi

if ! git -C "$REPO_ROOT" diff --quiet || ! git -C "$REPO_ROOT" diff --cached --quiet; then
  echo "ERROR: Repository has uncommitted changes: $REPO_ROOT" >&2
  echo "Commit, stash, or discard local changes before running sprint-upgrade." >&2
  exit 1
fi

BRANCH="$(git -C "$REPO_ROOT" rev-parse --abbrev-ref HEAD)"
if [ "$BRANCH" = "HEAD" ]; then
  echo "ERROR: Repository is in detached HEAD state. Checkout a branch first." >&2
  exit 1
fi

BEFORE_SHA="$(git -C "$REPO_ROOT" rev-parse --short HEAD)"
UPSTREAM="$(git -C "$REPO_ROOT" rev-parse --abbrev-ref --symbolic-full-name '@{u}' 2>/dev/null || true)"

if [ -n "$UPSTREAM" ]; then
  echo "Pulling latest changes for $BRANCH (tracking $UPSTREAM)..."
  git -C "$REPO_ROOT" pull --ff-only
else
  REMOTE="origin"
  if ! git -C "$REPO_ROOT" remote get-url "$REMOTE" >/dev/null 2>&1; then
    echo "ERROR: No upstream configured for '$BRANCH' and remote '$REMOTE' is missing." >&2
    echo "Set upstream or run: sprint-upgrade --repo <path> with a properly configured clone." >&2
    exit 1
  fi

  echo "Fetching and fast-forwarding $REMOTE/$BRANCH..."
  git -C "$REPO_ROOT" fetch "$REMOTE" "$BRANCH"
  git -C "$REPO_ROOT" merge --ff-only "$REMOTE/$BRANCH"
fi

AFTER_SHA="$(git -C "$REPO_ROOT" rev-parse --short HEAD)"
if [ "$BEFORE_SHA" = "$AFTER_SHA" ]; then
  echo "Already up to date at $AFTER_SHA"
else
  echo "Updated: $BEFORE_SHA -> $AFTER_SHA"
fi

echo "Running setup to refresh installed commands/skills..."
(
  cd "$REPO_ROOT"
  ./setup "${SETUP_ARGS[@]}"
)

echo "sprint-upgrade complete."
