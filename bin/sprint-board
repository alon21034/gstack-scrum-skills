#!/usr/bin/env bash
# sprint-board — Generate an HTML sprint dashboard from .sprint.json
# Usage: sprint-board [path-to-sprint-file] [--output path] [--open]
# Default sprint file resolution:
#   1) $CONDUCTOR_ROOT_PATH/.context/.sprint.json (if set and exists)
#   2) .context/.sprint.json in current directory
# Default output file: <sprint-file-dir>/sprint-board.html

set -euo pipefail

check_for_sprint_upgrade() {
  if [ "${SPRINT_SKIP_UPGRADE_CHECK:-0}" = "1" ]; then
    return 0
  fi

  local checker=""
  local script_dir
  local check_output
  local check_rc

  if command -v sprint-upgrade >/dev/null 2>&1; then
    checker="$(command -v sprint-upgrade)"
  else
    script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    if [ -x "$script_dir/sprint-upgrade" ]; then
      checker="$script_dir/sprint-upgrade"
    fi
  fi

  if [ -z "$checker" ]; then
    return 0
  fi

  if check_output="$("$checker" --check --quiet 2>/dev/null)"; then
    return 0
  else
    check_rc=$?
  fi

  case "$check_rc" in
    10)
      if [ -n "$check_output" ]; then
        printf '%s\n' "$check_output" >&2
      fi
      ;;
    *)
      # Keep command flow resilient when check cannot be completed.
      ;;
  esac
}

check_for_sprint_upgrade

usage() {
  cat <<'USAGE'
Usage: sprint-board [path-to-sprint-file] [--output path] [--open]

Options:
  --output <path>   Write HTML to this file path.
  --open            Open generated HTML in the default browser.
  -h, --help        Show this help.
USAGE
}

SPRINT_FILE_ARG=""
OUTPUT_FILE=""
AUTO_OPEN=0

while [ "$#" -gt 0 ]; do
  case "$1" in
    --output)
      if [ "$#" -lt 2 ]; then
        echo "ERROR: --output requires a file path" >&2
        exit 1
      fi
      OUTPUT_FILE="$2"
      shift
      ;;
    --open)
      AUTO_OPEN=1
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    -*)
      echo "ERROR: Unknown option: $1" >&2
      usage >&2
      exit 1
      ;;
    *)
      if [ -n "$SPRINT_FILE_ARG" ]; then
        echo "ERROR: Unexpected extra argument: $1" >&2
        usage >&2
        exit 1
      fi
      SPRINT_FILE_ARG="$1"
      ;;
  esac
  shift
done

command -v python3 >/dev/null 2>&1 || {
  echo "ERROR: python3 is required." >&2
  exit 1
}

resolve_sprint_file() {
  if [ -n "$SPRINT_FILE_ARG" ]; then
    if [ -f "$SPRINT_FILE_ARG" ]; then
      echo "$SPRINT_FILE_ARG"
      return 0
    fi
    return 1
  fi

  if [ -n "${CONDUCTOR_ROOT_PATH:-}" ] && [ -f "$CONDUCTOR_ROOT_PATH/.context/.sprint.json" ]; then
    echo "$CONDUCTOR_ROOT_PATH/.context/.sprint.json"
    return 0
  fi

  if [ -f ".context/.sprint.json" ]; then
    echo ".context/.sprint.json"
    return 0
  fi

  return 1
}

if ! SPRINT_FILE="$(resolve_sprint_file)"; then
  echo "No active sprint found. Run /sprint to start one."
  exit 1
fi

SPRINT_FILE="$(cd "$(dirname "$SPRINT_FILE")" && pwd)/$(basename "$SPRINT_FILE")"

if [ -z "$OUTPUT_FILE" ]; then
  OUTPUT_FILE="$(dirname "$SPRINT_FILE")/sprint-board.html"
fi

mkdir -p "$(dirname "$OUTPUT_FILE")"
OUTPUT_FILE="$(cd "$(dirname "$OUTPUT_FILE")" && pwd)/$(basename "$OUTPUT_FILE")"

python3 - "$SPRINT_FILE" "$OUTPUT_FILE" <<'PY'
import html
import json
import sys
from collections import defaultdict, deque
from datetime import datetime, timezone

sprint_path, output_path = sys.argv[1], sys.argv[2]

with open(sprint_path, "r", encoding="utf-8") as f:
    data = json.load(f)

sprint = data.get("sprint", {})
tasks = data.get("tasks", [])

now = datetime.now(timezone.utc)
id_to_status = {task.get("id"): task.get("status", "unknown") for task in tasks}

def as_text(value, fallback="-"):
    if value is None:
        return fallback
    text = str(value).strip()
    return text if text else fallback

def parse_iso(ts):
    ts = ts.strip()
    if ts.endswith("Z"):
        ts = ts[:-1] + "+00:00"
    dt = datetime.fromisoformat(ts)
    if dt.tzinfo is None:
        dt = dt.replace(tzinfo=timezone.utc)
    return dt.astimezone(timezone.utc)

def elapsed_label(started_at):
    if not started_at:
        return "not started"

    try:
        start_dt = parse_iso(str(started_at))
    except Exception:
        return "invalid timestamp"

    delta_seconds = int((now - start_dt).total_seconds())
    if delta_seconds < 0:
        delta_seconds = 0

    days, rem = divmod(delta_seconds, 86400)
    hours, rem = divmod(rem, 3600)
    minutes, _ = divmod(rem, 60)

    if days > 0:
        return f"{days}d {hours}h"
    if hours > 0:
        return f"{hours}h {minutes}m"
    return f"{minutes}m"

def task_sort_key(task):
    task_id = task.get("id")
    try:
        return (0, int(task_id))
    except Exception:
        return (1, str(task_id))

def node_sort_key(task_id):
    try:
        return (0, int(task_id))
    except Exception:
        return (1, str(task_id))

def status_class(status):
    return {
        "done": "done",
        "backlog": "backlog",
        "deleted": "deleted",
        "review": "review",
        "in-progress": "in-progress",
        "pending": "pending",
    }.get(status, "unknown")

def status_counts(items):
    counts = {
        "done": 0,
        "backlog": 0,
        "deleted": 0,
        "review": 0,
        "in-progress": 0,
        "pending": 0,
    }
    for task in items:
        status = task.get("status")
        if status in counts:
            counts[status] += 1
    return counts

def graph_status_style(status):
    return {
        "done": ("#ecfdf5", "#0f766e"),
        "backlog": ("#f3e8ff", "#7c3aed"),
        "deleted": ("#fee2e2", "#b91c1c"),
        "review": ("#dbeafe", "#1d4ed8"),
        "in-progress": ("#ffedd5", "#c2410c"),
        "pending": ("#f3f4f6", "#6b7280"),
        "missing": ("#fee2e2", "#b91c1c"),
    }.get(status, ("#e2e8f0", "#334155"))

def ellipsize(text, max_len):
    clean = as_text(text, "")
    if len(clean) <= max_len:
        return clean
    return clean[: max_len - 1] + "..."

def build_dependency_graph_svg(tasks_sorted, id_to_status):
    status_by_key = {str(task_id): status for task_id, status in id_to_status.items() if task_id is not None}
    nodes = {}
    edges = []
    adjacency = defaultdict(list)
    in_degree = defaultdict(int)

    for task in tasks_sorted:
        key = str(task.get("id"))
        nodes[key] = {
            "id": as_text(task.get("id")),
            "title": as_text(task.get("title")),
            "status": as_text(task.get("status"), "unknown"),
            "missing": False,
        }
        in_degree.setdefault(key, 0)

    for task in tasks_sorted:
        target_key = str(task.get("id"))
        for dep in (task.get("depends_on") or []):
            dep_key = str(dep)
            dep_exists = dep_key in nodes
            dep_status = status_by_key.get(dep_key)

            if not dep_exists:
                nodes[dep_key] = {
                    "id": as_text(dep),
                    "title": "Missing dependency task",
                    "status": "missing",
                    "missing": True,
                }
                in_degree.setdefault(dep_key, 0)

            edge_state = "resolved" if dep_exists and dep_status == "done" else "blocked"
            edges.append({"source": dep_key, "target": target_key, "state": edge_state})
            adjacency[dep_key].append(target_key)
            in_degree[target_key] += 1

    for key in nodes:
        adjacency.setdefault(key, [])
        in_degree.setdefault(key, 0)

    working_degrees = dict(in_degree)
    queue = deque(sorted((key for key, degree in working_degrees.items() if degree == 0), key=node_sort_key))
    levels = {key: 0 for key in queue}

    while queue:
        current = queue.popleft()
        current_level = levels.get(current, 0)
        for nxt in sorted(adjacency[current], key=node_sort_key):
            levels[nxt] = max(levels.get(nxt, 0), current_level + 1)
            working_degrees[nxt] -= 1
            if working_degrees[nxt] == 0:
                queue.append(nxt)

    unresolved = sorted((key for key, degree in working_degrees.items() if degree > 0), key=node_sort_key)
    if unresolved:
        cycle_level = max(levels.values(), default=0) + 1
        for key in unresolved:
            levels[key] = cycle_level

    columns = defaultdict(list)
    for key in nodes:
        columns[levels.get(key, 0)].append(key)

    ordered_columns = sorted(columns)
    for level in ordered_columns:
        columns[level].sort(key=node_sort_key)

    node_w = 240
    node_h = 72
    col_gap = 96
    row_gap = 24
    pad = 24

    column_heights = {
        level: (len(columns[level]) * node_h) + (max(0, len(columns[level]) - 1) * row_gap)
        for level in ordered_columns
    }
    inner_h = max(column_heights.values(), default=node_h)
    graph_h = inner_h + (pad * 2)
    graph_w = (pad * 2) + (len(ordered_columns) * node_w) + (max(0, len(ordered_columns) - 1) * col_gap)

    positions = {}
    for idx, level in enumerate(ordered_columns):
        x = pad + (idx * (node_w + col_gap))
        col_h = column_heights[level]
        y0 = pad + ((inner_h - col_h) / 2.0)
        for row_idx, key in enumerate(columns[level]):
            y = y0 + (row_idx * (node_h + row_gap))
            positions[key] = (x, y)

    svg_parts = [
        f"<svg class='dep-svg' viewBox='0 0 {graph_w} {graph_h}' role='img' aria-label='Sprint dependency graph'>",
        "<defs>",
        "<marker id='arrow-resolved' markerWidth='10' markerHeight='7' refX='8' refY='3.5' orient='auto'>",
        "<polygon points='0 0, 10 3.5, 0 7' fill='#166534' />",
        "</marker>",
        "<marker id='arrow-blocked' markerWidth='10' markerHeight='7' refX='8' refY='3.5' orient='auto'>",
        "<polygon points='0 0, 10 3.5, 0 7' fill='#b91c1c' />",
        "</marker>",
        "</defs>",
    ]

    for edge in edges:
        src_x, src_y = positions[edge["source"]]
        dst_x, dst_y = positions[edge["target"]]
        x1 = src_x + node_w
        y1 = src_y + (node_h / 2.0)
        x2 = dst_x
        y2 = dst_y + (node_h / 2.0)
        dx = max(48, abs(x2 - x1) * 0.5)
        c1x = x1 + dx
        c2x = x2 - dx
        state = edge["state"]
        stroke = "#166534" if state == "resolved" else "#b91c1c"
        marker = "arrow-resolved" if state == "resolved" else "arrow-blocked"
        svg_parts.append(
            f"<path d='M {x1:.1f} {y1:.1f} C {c1x:.1f} {y1:.1f}, {c2x:.1f} {y2:.1f}, {x2:.1f} {y2:.1f}' "
            f"stroke='{stroke}' stroke-width='2.3' fill='none' marker-end='url(#{marker})' opacity='0.9' />"
        )

    for key in sorted(nodes, key=node_sort_key):
        node = nodes[key]
        x, y = positions[key]
        fill, border = graph_status_style(node["status"])
        id_line = f"Task {node['id']}"
        title_line = ellipsize(node["title"], 32)
        status_line = "MISSING" if node["missing"] else as_text(node["status"], "unknown").upper()
        text_color = "#0f172a"
        svg_parts.append(
            f"<g transform='translate({x:.1f},{y:.1f})'>"
            f"<rect width='{node_w}' height='{node_h}' rx='12' ry='12' fill='{fill}' stroke='{border}' stroke-width='2' />"
            f"<text x='12' y='22' font-size='12' font-weight='700' fill='{text_color}'>{html.escape(id_line)}</text>"
            f"<text x='12' y='42' font-size='13' font-weight='600' fill='{text_color}'>{html.escape(title_line)}</text>"
            f"<text x='12' y='61' font-size='11' fill='{text_color}'>{html.escape(status_line)}</text>"
            "</g>"
        )

    svg_parts.append("</svg>")

    stats = {
        "total": len(edges),
        "resolved": sum(1 for edge in edges if edge["state"] == "resolved"),
        "blocked": sum(1 for edge in edges if edge["state"] == "blocked"),
        "missing_nodes": sum(1 for node in nodes.values() if node["missing"]),
    }
    return "".join(svg_parts), stats

tasks_sorted = sorted(tasks, key=task_sort_key)
counts = status_counts(tasks_sorted)
dependency_graph_svg, dependency_stats = build_dependency_graph_svg(tasks_sorted, id_to_status)

task_rows = []

for task in tasks_sorted:
    task_id = task.get("id")
    title = as_text(task.get("title"))
    status = as_text(task.get("status"), "unknown")
    workspace = as_text(task.get("workspace"), "-")
    branch = as_text(task.get("branch"), "-")
    elapsed = elapsed_label(task.get("started_at"))

    task_rows.append(
        "<tr>"
        f"<td>{html.escape(as_text(task_id))}</td>"
        f"<td>{html.escape(title)}</td>"
        f"<td><span class='badge {status_class(task.get('status'))}'>{html.escape(status)}</span></td>"
        f"<td>{html.escape(workspace)}</td>"
        f"<td><code>{html.escape(branch)}</code></td>"
        f"<td>{html.escape(elapsed)}</td>"
        "</tr>"
    )

summary = (
    f"{counts['done']}/{len(tasks_sorted)} done"
    f" | {counts['backlog']} backlog"
    f" | {counts['deleted']} deleted"
    f" | {counts['review']} in review"
    f" | {counts['in-progress']} in progress"
    f" | {counts['pending']} pending"
)

generated_at = now.strftime("%Y-%m-%d %H:%M:%S UTC")
sprint_topic = as_text(sprint.get("topic"), "(untitled sprint)")
sprint_status = as_text(sprint.get("status"), "unknown").upper()
dependency_summary = (
    f"{dependency_stats['resolved']} resolved"
    f" | {dependency_stats['blocked']} blocked"
    f" | {dependency_stats['missing_nodes']} missing refs"
)

html_doc = f"""<!doctype html>
<html lang=\"en\">
<head>
  <meta charset=\"utf-8\" />
  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />
  <title>Sprint Board - {html.escape(sprint_topic)}</title>
  <style>
    :root {{
      --bg: #f4f7fb;
      --card: #ffffff;
      --text: #0f172a;
      --muted: #475569;
      --border: #dce3ee;
      --accent: #1769aa;
      --done: #0f766e;
      --backlog: #7c3aed;
      --deleted: #b91c1c;
      --review: #1d4ed8;
      --in-progress: #c2410c;
      --pending: #6b7280;
      --resolved: #166534;
      --blocked: #b91c1c;
    }}
    * {{ box-sizing: border-box; }}
    body {{
      margin: 0;
      font-family: "Avenir Next", "Segoe UI", Helvetica, Arial, sans-serif;
      color: var(--text);
      background: radial-gradient(1200px 500px at 0% -10%, #dce8f8 0%, var(--bg) 60%);
    }}
    .wrap {{
      max-width: 1200px;
      margin: 24px auto;
      padding: 0 16px 24px;
    }}
    .hero {{
      background: linear-gradient(135deg, #0b3d91, #1769aa);
      color: #fff;
      border-radius: 14px;
      padding: 20px;
      box-shadow: 0 12px 28px rgba(11, 61, 145, 0.2);
    }}
    .hero h1 {{
      margin: 0 0 8px;
      font-size: 28px;
      line-height: 1.2;
    }}
    .meta {{
      margin: 0;
      font-size: 14px;
      opacity: 0.95;
    }}
    .card {{
      margin-top: 16px;
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 16px;
      box-shadow: 0 6px 18px rgba(15, 23, 42, 0.06);
    }}
    h2 {{ margin: 0 0 12px; font-size: 19px; }}
    .summary {{
      font-weight: 600;
      color: var(--accent);
      margin: 0;
      word-break: break-word;
    }}
    .table-wrap {{
      width: 100%;
      overflow-x: auto;
      border: 1px solid var(--border);
      border-radius: 10px;
      background: #fff;
    }}
    table {{
      width: 100%;
      border-collapse: collapse;
      min-width: 840px;
    }}
    th, td {{
      text-align: left;
      padding: 10px 12px;
      border-bottom: 1px solid #eef2f7;
      font-size: 14px;
      vertical-align: top;
    }}
    th {{
      background: #f8fafc;
      color: #0f172a;
      font-size: 12px;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }}
    tr:last-child td {{ border-bottom: none; }}
    .badge {{
      display: inline-block;
      border-radius: 999px;
      padding: 3px 10px;
      font-size: 12px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.03em;
      color: #fff;
      white-space: nowrap;
    }}
    .done {{ background: var(--done); }}
    .backlog {{ background: var(--backlog); }}
    .deleted {{ background: var(--deleted); }}
    .review {{ background: var(--review); }}
    .in-progress {{ background: var(--in-progress); }}
    .pending {{ background: var(--pending); }}
    .resolved {{ background: var(--resolved); }}
    .blocked {{ background: var(--blocked); }}
    .unknown {{ background: #334155; }}
    .graph-wrap {{
      width: 100%;
      overflow-x: auto;
      border: 1px solid var(--border);
      border-radius: 10px;
      background: #fff;
    }}
    .dep-svg {{
      display: block;
      width: 100%;
      min-width: 740px;
      height: auto;
      background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
    }}
    .graph-summary {{
      margin: 0 0 10px;
      color: var(--muted);
      font-size: 14px;
      font-weight: 600;
    }}
    .empty {{
      margin: 0;
      color: var(--muted);
      font-style: italic;
    }}
    code {{
      font-family: "SFMono-Regular", Menlo, Consolas, monospace;
      font-size: 12px;
      background: #f8fafc;
      border: 1px solid #e2e8f0;
      border-radius: 6px;
      padding: 2px 6px;
      white-space: nowrap;
    }}
    @media (max-width: 760px) {{
      .hero h1 {{ font-size: 22px; }}
      th, td {{ padding: 9px 10px; font-size: 13px; }}
    }}
  </style>
</head>
<body>
  <main class=\"wrap\">
    <section class=\"hero\">
      <h1>{html.escape(sprint_topic)}</h1>
      <p class=\"meta\">Status: {html.escape(sprint_status)} | {len(tasks_sorted)} tasks | Generated: {html.escape(generated_at)}</p>
      <p class=\"meta\">Source: <code>{html.escape(sprint_path)}</code></p>
    </section>

    <section class=\"card\">
      <h2>Progress</h2>
      <p class=\"summary\">{html.escape(summary)}</p>
    </section>

    <section class=\"card\">
      <h2>Tasks</h2>
      <div class=\"table-wrap\">
        <table>
          <thead>
            <tr>
              <th>ID</th>
              <th>Title</th>
              <th>Status</th>
              <th>Workspace</th>
              <th>Branch</th>
              <th>Elapsed</th>
            </tr>
          </thead>
          <tbody>
            {''.join(task_rows) if task_rows else '<tr><td colspan="6">No tasks found.</td></tr>'}
          </tbody>
        </table>
      </div>
    </section>

    <section class=\"card\">
      <h2>Dependencies</h2>
      <p class=\"graph-summary\">{html.escape(dependency_summary)}</p>
      <div class=\"graph-wrap\">{dependency_graph_svg}</div>
      {'<p class="empty" style="margin-top:10px;">No dependency edges found. Tasks are currently independent.</p>' if dependency_stats['total'] == 0 else ''}
    </section>
  </main>
</body>
</html>
"""

with open(output_path, "w", encoding="utf-8") as f:
    f.write(html_doc)
PY

echo "Sprint board HTML generated: $OUTPUT_FILE"

if [ "$AUTO_OPEN" -eq 1 ]; then
  if command -v open >/dev/null 2>&1; then
    open "$OUTPUT_FILE"
    echo "Opened in default browser."
    exit 0
  fi

  if command -v xdg-open >/dev/null 2>&1; then
    xdg-open "$OUTPUT_FILE" >/dev/null 2>&1 &
    echo "Opened in default browser."
    exit 0
  fi

  echo "Could not auto-open browser on this system."
fi

if command -v open >/dev/null 2>&1; then
  echo "Open with: open \"$OUTPUT_FILE\""
else
  echo "Open the HTML file in your browser: $OUTPUT_FILE"
fi
